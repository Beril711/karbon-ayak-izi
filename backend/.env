# ── DJANGO ────────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-change-this-in-production-use-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── VERİTABANI ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://gcuser:gcpassword@localhost:5432/greencampus

# ── REDIS & CELERY ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006,exp://localhost:8081

# ── EMAIL ────────────────────────────────────────────────────────────────────
DEFAULT_FROM_EMAIL=noreply@greencampus.app
# Production'da smtp.gmail.com vb. kullan
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# ── ÜNİVERSİTE DOMAİNLERİ ────────────────────────────────────────────────────
ALLOWED_UNIVERSITY_DOMAINS=ahievran.edu.tr,edu.tr

# ── PUSH BİLDİRİM ────────────────────────────────────────────────────────────
FCM_SERVER_KEY=your-firebase-cloud-messaging-server-key

# ── İZLEME ───────────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxxx@sentry.io/xxxxx

# ── EMİSYON FAKTÖR API ───────────────────────────────────────────────────────
EMISSION_FACTOR_API_KEY=your-climatiq-api-key
